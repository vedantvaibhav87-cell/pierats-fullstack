# Postgres connection string
DATABASE_URL=postgres://pierats:pierats@localhost:5432/pierats

# Long random string used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Origin of the frontend dev server (Vite default) — used for CORS + cookies
CLIENT_ORIGIN=http://localhost:5173

# development | production
NODE_ENV=development

PORT=4000
